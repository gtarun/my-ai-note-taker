{
  "expo": {
    "name": "AI Notes",
    "slug": "ai-note-taker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "mufathom",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AI Notes records meeting audio only when you explicitly start recording.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.gtarun.mu-fathom",
      "appleTeamId": "Z4L8SXT9S6"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-audio",
        {
          "enableBackgroundRecording": true,
          "microphonePermission": "AI Notes records meeting audio only when you explicitly start recording."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "supabaseUrl": "https://ulgbdlhwjwsyflzfdhma.supabase.co",
      "supabaseAnonKey": "sb_publishable__eiWD9e4H3e1oMUYrPQ0lA_ZABVjiEo",
      "googleDriveConnectFunctionName": "google-drive-connect-url",
      "router": {},
      "eas": {
        "projectId": "ff5da993-fdaa-47ef-8a52-1d582508b263"
      }
    },
    "owner": "gtarun_vp"
  }
}
